[package]
authors = ["drbh"]
categories = ["command-line-utilities", "science"]
description = "High-performance FASTQ preprocessing tool - often faster than fastp with the same interface"
documentation = "https://drbh.github.io/fasterp/"
edition = "2021"
homepage = "https://drbh.github.io/fasterp/"
keywords = ["bioinformatics", "fastq", "genomics", "preprocessing", "quality-control"]
license = "MIT"
name = "fasterp"
readme = "README.md"
repository = "https://github.com/drbh/fasterp"
version = "0.2.1"

[features]
default = ["native"]
native = [
  "dep:crossbeam-channel",
  "dep:num_cpus",
  "dep:rayon",
  "dep:aws-sdk-s3",
  "dep:aws-config",
  "dep:tokio",
  "dep:ureq",
  "dep:libdeflater",
  "dep:gzp",
  "flate2/zlib-ng",
]
wasm = ["dep:wasm-bindgen", "dep:js-sys", "flate2/rust_backend"]

[dependencies]
anyhow = "1.0"
clap = {version = "4.5", features = ["derive"]}
flate2 = {version = "1.0", default-features = false}
indexmap = {version = "2.0", features = ["serde"]}
memchr = "2.7"
once_cell = "1.20"
rustc-hash = "2.0"
serde = {version = "1.0", features = ["derive"]}
serde_json = "1.0"

# Native-only dependencies (threading, networking, optimized compression)
aws-config = {version = "1.0", optional = true}
aws-sdk-s3 = {version = "1.0", optional = true}
crossbeam-channel = {version = "0.5", optional = true}
gzp = {version = "0.11", features = ["deflate_rust"], default-features = false, optional = true}
libdeflater = {version = "1.21", optional = true}
num_cpus = {version = "1.16", optional = true}
rayon = {version = "1.10", optional = true}
tokio = {version = "1.0", features = ["rt-multi-thread"], optional = true}
ureq = {version = "2.9", default-features = false, features = ["tls"], optional = true}

# WASM-only dependencies
js-sys = {version = "=0.3.69", optional = true}
wasm-bindgen = {version = "=0.2.92", optional = true}

# Optional features
zstd = {version = "0.13", optional = true}

[lib]
crate-type = ["cdylib", "rlib"]

[dev-dependencies]
assert_cmd = "2.0"
criterion = "0.5"
predicates = "3.0"
rand = "0.8"
tempfile = "3.8"

[profile.release]
codegen-units = 1 # Better optimization (slower compile, faster runtime)
lto = "fat" # Full Link Time Optimization across all crates
opt-level = 3 # Maximum optimization
overflow-checks = false # Disable integer overflow checks for performance
panic = "abort" # Smaller/faster code by not unwinding
strip = false # Keep debug symbols for profiling (change to true for production)
